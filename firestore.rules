rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email.lower() == 'jirehstar6@gmail.com' || 
              request.auth.uid == 'jirehstar6_bypass');
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collection Rules ---

    // Settings
    match /settings/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    // General collections allowed for anyone to read, only Admin can write
    match /{collectionName}/{docId} {
      allow read: if collectionName in ['products', 'services', 'videos', 'reals', 'notifications', 'ads', 'heroBanners'];
      allow write: if isAdmin() && collectionName in ['products', 'services', 'videos', 'reals', 'notifications', 'ads', 'heroBanners'];
    }

    // Team Members
    match /team/{memberId} {
      function isValidTeamMember(data) {
        return data.keys().hasAll(['name', 'role', 'img', 'createdAt']) &&
               data.keys().size() <= 8 &&
               data.name is string && data.name.size() <= 200 &&
               data.role is string && data.role.size() <= 200 &&
               data.img is string && data.img.size() <= 1000000 &&
               data.createdAt is number;
      }
      allow read: if true;
      allow create, update: if isAdmin() && isValidTeamMember(incoming());
      allow delete: if isAdmin();
    }

    // User Profiles
    match /users/{userId} {
      function isValidProfile(data) {
        return data.keys().hasAll(['uid', 'email', 'fullName', 'occupation', 'phone', 'city', 'role', 'completedAt']) &&
               data.keys().size() <= 15 &&
               data.uid == userId &&
               data.email is string &&
               data.fullName is string &&
               data.occupation is string &&
               data.phone is string &&
               data.city is string &&
               data.role is string;
      }
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if isSignedIn() && request.auth.uid == userId && isValidProfile(incoming());
    }

    // Market Items
    match /market_items/{itemId} {
      function isValidMarketItem(data) {
        return data.keys().hasAll(['name', 'category', 'price', 'location', 'creatorId', 'createdAt']) &&
               data.keys().size() <= 12 &&
               data.creatorId is string &&
               data.createdAt is number;
      }

      allow list: if true; 
      allow get: if true; 
      
      allow create: if isSignedIn() && (
        isAdmin() || (
          isValidMarketItem(incoming()) &&
          incoming().creatorId == request.auth.uid
        )
      );
      
      allow update: if isSignedIn() && (
        isAdmin() || (
          incoming().creatorId == existing().creatorId &&
          request.auth.uid == existing().creatorId
        )
      );

      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == existing().creatorId);
    }

    // Visits - CRITICAL FIX: Ensure allow create works for anyone
    match /visits/{visitId} {
      function isValidVisit(data) {
        return data.keys().hasAll(['userAgent', 'path', 'createdAt']) &&
               data.keys().size() <= 6 &&
               data.userAgent is string && data.userAgent.size() <= 1000 &&
               data.path is string && data.path.size() <= 2000 &&
               (data.userId == null || data.userId is string) &&
               (data.email == null || data.email is string) &&
               data.createdAt is number;
      }
      allow create: if isValidVisit(incoming());
      allow read: if isAdmin();
    }

    // Messages
    match /messages/{messageId} {
      function isValidMessage(data) {
        return data.keys().hasAll(['name', 'phone', 'message', 'isRead', 'createdAt']) &&
               data.keys().size() <= 8 &&
               data.name is string && data.name.size() <= 200 &&
               data.phone is string && data.phone.size() <= 50 &&
               data.message is string && data.message.size() <= 5000 &&
               data.isRead is bool &&
               data.createdAt is number;
      }
      allow create: if isValidMessage(incoming());
      allow read, update, delete: if isAdmin();
    }
  }
}
