{
  "entities": {
    "MarketItem": {
      "title": "Market Item",
      "description": "Item sold in the market (e.g., sheep, vegetables, snacks)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "string" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "number" },
        "shopName": { "type": "string" },
        "description": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["name", "category", "price", "location", "creatorId", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Premium fresh product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "badge": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "price", "imageUrl", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "Service offered by the platform",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "description", "imageUrl", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "Video content",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "caption": { "type": "string" },
        "src": { "type": "string" },
        "srcType": { "type": "string", "enum": ["file", "youtube", "facebook"] },
        "thumbnail": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "src", "srcType", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Application settings and content",
      "type": "object",
      "properties": {
        "whatsapp": { "type": "string" },
        "call": { "type": "string" },
        "heroVideoId": { "type": "string" },
        "publicityVideoId": { "type": "string" },
        "publicityTitle": { "type": "string" },
        "publicitySubtitle": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "bannerTitle": { "type": "string" },
        "bannerDesc": { "type": "string" },
        "statsTitle": { "type": "string" },
        "statsValue1": { "type": "string" },
        "statsLabel1": { "type": "string" },
        "statsValue2": { "type": "string" },
        "statsLabel2": { "type": "string" },
        "statsQuote": { "type": "string" },
        "feature1Title": { "type": "string" },
        "feature1Desc": { "type": "string" },
        "feature1Img": { "type": "string" },
        "feature2Title": { "type": "string" },
        "feature2Desc": { "type": "string" },
        "feature2Img": { "type": "string" },
        "feature3Title": { "type": "string" },
        "feature3Desc": { "type": "string" },
        "feature3Img": { "type": "string" }
      }
    },
    "Real": {
      "title": "Real",
      "description": "Portfolio item or creative work",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "imageUrl", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error"] },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "message", "type", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "occupation": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "role": { "type": "string" },
        "about": { "type": "string" },
        "completedAt": { "type": "number" }
      },
      "required": ["uid", "email", "fullName", "occupation", "phone", "city", "role", "completedAt"]
    },
    "Ad": {
      "title": "Advertisement",
      "description": "Publicity banner or ad",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "subtitle", "imageUrl", "active", "createdAt"]
    },
    "HeroBanner": {
      "title": "Hero Banner",
      "description": "Main banner at the top of the dashboard",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subtitle": { "type": "string" },
        "heading": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "subtitle", "heading", "imageUrl", "active", "createdAt"]
    },
    "TeamMember": {
      "title": "Team Member",
      "description": "Information about a team member",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "img": { "type": "string" },
        "phone": { "type": "string" },
        "description": { "type": "string" },
        "prestations": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "role", "img", "createdAt"]
    },
    "Visit": {
      "title": "Visit",
      "description": "Log of a user visiting the application",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "userAgent": { "type": "string" },
        "path": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userAgent", "path", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "User message or inquiry",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "phone", "message", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and onboarding data"
    },
    "/market_items/{itemId}": {
      "schema": "MarketItem",
      "description": "Collection of items available in the market"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Premium fresh products"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Platform services"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "App videos"
    },
    "/reals/{realId}": {
      "schema": "Real",
      "description": "Djapero Reals"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "System notifications"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Publicity ads"
    },
    "/heroBanners/{bannerId}": {
      "schema": "HeroBanner",
      "description": "Top dashboard hero banners"
    },
    "/team/{memberId}": {
      "schema": "TeamMember",
      "description": "Management of team members"
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Log of user visits"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "User messages and inquiries"
    },
    "/settings/main": {
      "schema": "Settings",
      "description": "Main app settings"
    }
  }
}
